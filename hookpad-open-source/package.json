{
  "name": "hookpad",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "compile:contracts": "hardhat compile",
    "deploy:xlayer-testnet": "hardhat run scripts/deploy.js --network xlayerTestnet",
    "deploy:v4:xlayer-testnet": "hardhat run scripts/deploy-v4-testnet.js --network xlayerTestnet",
    "deploy:v4:xlayer-mainnet": "hardhat run scripts/deploy-v4-mainnet.js --network xlayerMainnet",
    "demo:xlayer-testnet": "hardhat run scripts/run-demo-swaps.js --network xlayerTestnet",
    "demo:market:xlayer-testnet": "hardhat run scripts/deploy-market-demo.js --network xlayerTestnet"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@uniswap/v4-core": "^1.0.2",
    "@uniswap/v4-periphery": "^1.0.3",
    "@vitejs/plugin-react": "^5.1.1",
    "ethers": "^6.16.0",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "solmate": "^6.8.0",
    "vite": "^7.2.4"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "hardhat": "^2.28.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
